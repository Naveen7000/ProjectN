## Global Runtime Error Capture

File: src/index.js or src/main.jsx

import { errorLoggerService } from './services/errorLoggerService';

window.onerror = function (message, source, lineno, colno, error) {
  errorLoggerService.send({
    errorId: `err_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
    message: error?.message ?? String(message),
    name: error?.name ?? 'GlobalError',
    stack: error?.stack ?? `${source}:${lineno}:${colno}`,
    componentStack: null,
    url: window.location.href,
    userAgent: navigator.userAgent,
    timestamp: new Date().toISOString(),
    context: 'window.onerror',
  });
  return false;
};

window.addEventListener('unhandledrejection', (event) => {
  const error = event.reason;

  errorLoggerService.send({
    errorId: `err_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
    message: error?.message ?? String(error),
    name: error?.name ?? 'UnhandledRejection',
    stack: error?.stack ?? null,
    componentStack: null,
    url: window.location.href,
    userAgent: navigator.userAgent,
    timestamp: new Date().toISOString(),
    context: 'unhandledrejection',
  });
});

