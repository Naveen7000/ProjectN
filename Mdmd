## Integration at App Entry Point

Option A — Wrap entire app (recommended)

File: src/App.jsx or src/main.jsx

import React from 'react';
import ErrorBoundary from './components/ErrorBoundary/ErrorBoundary';
import Router from './Router';

function App() {
  return (
    <ErrorBoundary context="app-root">
      <Router />
    </ErrorBoundary>
  );
}

export default App;


Option B — Granular boundaries per feature section

function App() {
  return (
    <ErrorBoundary context="app-root">
      <Header />
      <ErrorBoundary context="main-content" fallback={ContentFallback}>
        <MainContent />
      </ErrorBoundary>
      <ErrorBoundary context="sidebar">
        <Sidebar />
      </ErrorBoundary>
    </ErrorBoundary>
  );
}

