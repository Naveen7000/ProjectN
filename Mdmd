## The Error Logger Service

File: src/services/errorLoggerService.js

const API_ENDPOINT =
  process.env.REACT_APP_ERROR_LOG_URL ||
  import.meta.env?.VITE_ERROR_LOG_URL ||
  '/api/log/ui-error';

const isDev = process.env.NODE_ENV === 'development';

async function send(payload) {
  if (isDev) {
    console.group('[ErrorLogger]');
    console.error('Error captured:', payload.message);
    console.info('Full payload:', payload);
    console.groupEnd();
    return;
  }

  try {
    await fetch(API_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      keepalive: true,
      body: JSON.stringify(payload),
    });
  } catch (networkError) {
    console.warn('[ErrorLogger] Failed to send error log:', networkError.message);
  }
}

export const errorLoggerService = { send };


Using Axios instead of fetch:

async function send(payload) {
  if (isDev) { return; }
  try {
    await axios.post(API_ENDPOINT, payload, { timeout: 5000 });
  } catch {
    // Silent — never throw from logger
  }
}

