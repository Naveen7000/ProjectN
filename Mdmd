## Implementation — Functional + Hook Pattern (React 18+)

React does not support functional ErrorBoundaries natively. Keep a small class-based boundary but expose a clean functional wrapper hook for manual error logging.

File: src/hooks/useErrorLogger.js

import { useCallback } from 'react';
import { errorLoggerService } from '../services/errorLoggerService';

export function useErrorLogger({ context = 'unknown' } = {}) {
  const logError = useCallback(
    (error, additionalMeta = {}) => {
      errorLoggerService.send({
        errorId: `err_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
        message: error?.message ?? String(error),
        name: error?.name ?? 'UnknownError',
        stack: error?.stack ?? null,
        componentStack: null,
        url: window.location.href,
        userAgent: navigator.userAgent,
        timestamp: new Date().toISOString(),
        context,
        ...additionalMeta,
      });
    },
    [context]
  );

  return { logError };
}


Example usage in an async handler:

function PaymentForm() {
  const { logError } = useErrorLogger({ context: 'PaymentForm' });

  const handleSubmit = async () => {
    try {
      await submitPayment(formData);
    } catch (err) {
      logError(err, { orderId: formData.orderId });
    }
  };
}

